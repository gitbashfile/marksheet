app.delete("/students/:roll_no", async (req, res) => {
  const { roll_no } = req.params;

  try {
    await pool.query(
      "DELETE FROM students WHERE roll_no = $1",
      [roll_no]
    );

    res.send("Deleted");
  } catch (err) {
    console.error(err);
    res.status(500).send("Error deleting");
  }
});